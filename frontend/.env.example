# Copy to .env.local; do NOT commit .env.local

# Get a free project id at https://cloud.reown.com (formerly WalletConnect)
NEXT_PUBLIC_WC_PROJECT_ID=

# Filled by your deploy step
NEXT_PUBLIC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MINING_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GENESIS_ADDRESS=0x0000000000000000000000000000000000000000

# Optional — pin to a specific RPC. Falls back to public RPC if blank.
NEXT_PUBLIC_RPC_URL=
