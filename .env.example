# Copy to .env and fill in. NEVER commit .env.
# Use a fresh deployer key with only the gas you need.

DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Alchemy / Infura / QuickNode endpoints
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Etherscan v2 API key (used for verification)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Mining start delay in hours after deployment (default 24)
MINING_START_DELAY_HOURS=24

# Uniswap V4 mainnet addresses (verify before deploy from
# https://docs.uniswap.org/contracts/v4/deployments)
V4_POOL_MANAGER=0x000000000004444c5dC75cB358380D2e3dE08A90
V4_POSITION_MANAGER=0xbD216513d74C8cf14cF4747E6AaA6420FF64ee9e
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3
